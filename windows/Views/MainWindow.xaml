<Window x:Class="FinanceAccountant.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="财务记账工具 v1.0.0" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧主区域 -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <TextBlock Grid.Row="0" Text="财务记账工具" FontSize="28" FontWeight="Bold" Margin="0,0,0,15" Foreground="#4ECDC4"/>

            <!-- 筛选区域 -->
            <Grid Grid.Row="1" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="月份：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1" x:Name="MonthCombo" Width="100" Margin="0,0,15,0"
                          ItemsSource="{Binding MonthList}" SelectionChanged="MonthCombo_SelectionChanged"/>

                <TextBlock Grid.Column="2" Text="类型：" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Grid.Column="3" Width="100" ItemsSource="{Binding TypeFilter}"
                          SelectedItem="{Binding SelectedType}" Margin="0,0,15,0"/>

                <Button Grid.Column="4" Content="导出 CSV" Command="{Binding ExportCsvCommand}" Margin="0,0,10,0"/>
                <Button Grid.Column="5" Content="导出 Excel" Command="{Binding ExportExcelCommand}"/>
            </Grid>

            <!-- 统计卡片 -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="10" Padding="15" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="收入" FontSize="14" Foreground="#888"/>
                        <TextBlock Text="{Binding TotalIncome, StringFormat='{}{0:C}'}" FontSize="24" Foreground="#4ECDC4" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="10" Padding="15" Margin="8,0">
                    <StackPanel>
                        <TextBlock Text="支出" FontSize="14" Foreground="#888"/>
                        <TextBlock Text="{Binding TotalExpense, StringFormat='{}{0:C}'}" FontSize="24" Foreground="#FF6B6B" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#2D2D2D" CornerRadius="10" Padding="15" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="结余" FontSize="14" Foreground="#888"/>
                        <TextBlock Text="{Binding Balance, StringFormat='{}{0:C}'}" FontSize="24" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#96CEB4"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Balance, Converter={StaticResource NegativeConverter}}" Value="True">
                                            <Setter Property="Foreground" Value="#FF6B6B"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 图表区域 -->
            <Grid Grid.Row="3" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 饼图 -->
                <Border Grid.Column="0" Background="#2D2D2D" CornerRadius="10" Padding="15" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="支出分类" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <lvc:PieChart Grid.Row="1" Series="{Binding PieSeries}" LegendPosition="Right"/>
                    </Grid>
                </Border>

                <!-- 折线图 -->
                <Border Grid.Column="1" Background="#2D2D2D" CornerRadius="10" Padding="15" Margin="8,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="每日收支趋势" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <lvc:CartesianChart Grid.Row="1" Series="{Binding LineSeries}" XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 右侧记账表单和列表 -->
        <Grid Grid.Column="1" Margin="15,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 添加账单表单 -->
            <Border Grid.Row="0" Background="#2D2D2D" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="添加账单" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton x:Name="IncomeRadio" Content="收入" Foreground="White" GroupName="Type"
                                     IsChecked="True" Checked="TypeRadio_Changed" Margin="0,0,20,0"/>
                        <RadioButton x:Name="ExpenseRadio" Content="支出" Foreground="White" GroupName="Type"
                                     Checked="TypeRadio_Changed"/>
                    </StackPanel>

                    <TextBlock Text="分类" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CategoryCombo" Margin="0,0,0,10" SelectionChanged="CategoryCombo_SelectionChanged">
                        <ComboBoxItem Content="工资"/><ComboBoxItem Content="奖金"/><ComboBoxItem Content="投资"/>
                        <ComboBoxItem Content="兼职"/><ComboBoxItem Content="其他收入"/>
                    </ComboBox>

                    <TextBlock Text="金额" Margin="0,0,0,5"/>
                    <TextBox x:Name="AmountBox" Text="{Binding NewAmount}" Margin="0,0,0,10"/>

                    <TextBlock Text="日期" Margin="0,0,0,5"/>
                    <DatePicker x:Name="DatePicker" SelectedDate="{Binding NewDate}" Margin="0,0,0,10"/>

                    <TextBlock Text="备注" Margin="0,0,0,5"/>
                    <TextBox x:Name="NoteBox" Text="{Binding NewNote}" Margin="0,0,0,15"/>

                    <Button Content="添加账单" Command="{Binding AddTransactionCommand}" Background="#4ECDC4"/>
                </StackPanel>
            </Border>

            <!-- 账单列表 -->
            <Border Grid.Row="1" Background="#2D2D2D" CornerRadius="10" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="账单列表" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

                    <ListView Grid.Row="1" ItemsSource="{Binding FilteredTransactions}"
                              Background="Transparent" BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#3A3A3A" CornerRadius="5" Padding="12" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Category}" FontWeight="Bold" FontSize="14"/>
                                            <TextBlock Text="{Binding Date, StringFormat='{}{0:yyyy-MM-dd}'}" Foreground="#888" FontSize="12"/>
                                            <TextBlock Text="{Binding Note}" Foreground="#666" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="{Binding Amount, StringFormat='{}{0:C}'}"
                                                   FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,15,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FF6B6B"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Income">
                                                            <Setter Property="Foreground" Value="#4ECDC4"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Button Grid.Column="2" Content="删除" Background="#FF6B6B" Padding="10,5"
                                                Click="DeleteButton_Click" Tag="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>