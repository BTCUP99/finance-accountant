<Application x:Class="FinanceAccountant.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- 全局深色主题 -->
            <SolidColorBrush x:Key="DarkBackground" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="DarkSurface" Color="#2D2D2D"/>
            <SolidColorBrush x:Key="DarkText" Color="#E0E0E0"/>
            <SolidColorBrush x:Key="AccentGreen" Color="#4ECDC4"/>
            <SolidColorBrush x:Key="AccentRed" Color="#FF6B6B"/>

            <Style TargetType="Window">
                <Setter Property="Background" Value="{StaticResource DarkBackground}"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>